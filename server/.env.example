# Copy this file to server/.env and fill in your key.
#
# SerpAPI powers the live Google Shopping price comparison.
# Get a free key (a 64-character hex string) at:
#     https://serpapi.com/manage-api-key
#
# Leave SERPAPI_KEY blank to run on built-in demo data — the whole flow still
# works end-to-end, just with deterministic sample prices.
SERPAPI_KEY=

# --- Optional overrides (sensible defaults apply if omitted) ---
# MARKET_COUNTRY=in
# MARKET_LANGUAGE=en
# MARKET_LOCATION=India
# MAX_RESULTS=15
# REWARDS_CACHE_TTL=3600
# SERPAPI_TIMEOUT=30
# HTTP_TIMEOUT=9
